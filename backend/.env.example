# Server Configuration
PORT=5001
NODE_ENV=production
BACKEND_URL=https://api.yourdomain.com

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/salesmind?retryWrites=true&w=majority

# JWT Secrets
# Generate strong, random strings for these in production
JWT_SECRET=your_super_secret_jwt_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-key

# Client URL (Frontend URL)
CLIENT_URL=https://your-frontend-site.com

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=5242880 # 5MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# OAuth Credentials
# These must match the callback URLs configured in Google/GitHub consoles
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
